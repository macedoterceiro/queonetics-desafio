    {
      "name": "03 - Vehicle Login Force",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();\r",
              "\r",
              "pm.environment.set(\"vehicleLoginId\", response.id);\r",
              "pm.environment.set(\"loggedVehicleId\", response.vehicleId);\r",
              "pm.environment.set(\"loggedDriverId\", response.driverId);\r",
              "\r",
              "pm.test(\"Vehicle force login succeeded\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Vehicle login data saved\", function () {\r",
              "    pm.expect(pm.environment.get(\"vehicleLoginId\")).to.not.be.empty;\r",
              "    pm.expect(String(pm.environment.get(\"loggedVehicleId\"))).to.eql(String(pm.environment.get(\"vehicleId\")));\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disabledSystemHeaders": {
          "content-type": true
        }
      },
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "{{authorization}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/driverapp/vehicle/login/force?vehicleId={{vehicleId}}&customerId={{customerId}}&driverId={{driverId}}",
