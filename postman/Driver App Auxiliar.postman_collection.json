    {
      "name": "x2 - Settings",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const vehicles = pm.response.json();\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"There is at least one allowed vehicle\", function () {\r",
              "    pm.expect(vehicles).to.be.an(\"array\");\r",
              "    pm.expect(vehicles.length).to.be.greaterThan(0);\r",
              "});\r",
              "\r",
              "const vehicle = vehicles[0];\r",
              "\r",
              "pm.environment.set(\"vehicleId\", vehicle.vehicleId);\r",
              "pm.environment.set(\"vehiclePlate\", vehicle.vehiclePlate);\r",
              "pm.environment.set(\"equipmentId\", vehicle.equipmentId || \"\");\r",
              "pm.environment.set(\"equipmentSerial\", vehicle.equipmentSerial || \"\");\r",
              "\r",
              "pm.test(\"Vehicle data was saved\", function () {\r",
              "    pm.expect(pm.environment.get(\"vehicleId\")).to.not.be.empty;\r",
              "    pm.expect(pm.environment.get(\"vehiclePlate\")).to.not.be.empty;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
