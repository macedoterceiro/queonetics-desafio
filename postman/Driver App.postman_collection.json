  },
  "item": [
    {
      "name": "01 - Authenticate App",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();\r",
              "const requestBody = JSON.parse(pm.request.body.raw);\r",
              "\r",
              "const authorization = pm.response.headers.get(\"Authorization\");\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Authorization header exists\", function () {\r",
              "    pm.expect(authorization).to.not.be.null;\r",
              "});\r",
              "\r",
              "pm.test(\"Driver was authenticated\", function () {\r",
              "    pm.expect(response).to.have.property(\"id\");\r",
              "    pm.expect(response).to.have.property(\"authCustomerId\");\r",
              "    pm.expect(response).to.have.property(\"name\");\r",
              "});\r",
              "\r",
              "pm.environment.set(\"authorization\", authorization);\r",
              "pm.environment.set(\"driverId\", response.id);\r",
              "pm.environment.set(\"customerId\", response.authCustomerId);\r",
              "pm.environment.set(\"login\", requestBody.login);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "packages": {},
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"appVersion\": \"4.6.2\",\r\n    \"attempts\": 0,\r\n    \"login\": \"ze-driver\",\r\n    \"notificationToken\": \"\",\r\n    \"notificationTokenMessage\": true,\r\n    \"password\": \"cilada\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/driverapp/auth",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "driverapp",
            "auth"
          ]
        }
      },
      "response": []
    },
    {
      "name": "02 - Vehicle Allowed",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const vehicles = pm.response.json();\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"There is at least one allowed vehicle\", function () {\r",
              "    pm.expect(vehicles).to.be.an(\"array\").that.is.not.empty;\r",
              "});\r",
              "\r",
              "const vehicle = vehicles.find(v => v.vehicleId);\r",
              "\r",
              "pm.test(\"A valid vehicle was found\", function () {\r",
              "    pm.expect(vehicle).to.not.be.undefined;\r",
              "});\r",
              "\r",
              "pm.environment.set(\"vehicleId\", vehicle.vehicleId);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "{{authorization}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": ""
        },
        "url": {
          "raw": "{{baseUrl}}/driverapp/vehicle/allowed",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "driverapp",
            "vehicle",
            "allowed"
          ]
        }
      },
      "response": []
    },
    {
      "name": "03 - Vehicle Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Driver logged into selected vehicle\", function () {\r",
              "    pm.expect(response).to.have.property(\"vehicleId\");\r",
              "    pm.expect(String(response.vehicleId)).to.eql(String(pm.environment.get(\"vehicleId\")));\r",
              "});\r",
              "\r",
              "pm.test(\"Driver login returned valid data\", function () {\r",
              "    pm.expect(response).to.have.property(\"driverId\");\r",
              "    pm.expect(response).to.have.property(\"identificationType\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disabledSystemHeaders": {}
      },
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "{{authorization}}",
            "type": "text"
          },
          {
            "key": "Customer",
            "value": "{{customerId}}",
            "type": "text"
          },
          {
            "key": "Login",
            "value": "{{login}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/driverapp/vehicle/login?vehicleId={{vehicleId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "driverapp",
            "vehicle",
            "login"
          ],
          "query": [
            {
              "key": "vehicleId",
              "value": "{{vehicleId}}"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "04 - Vehicle Logout",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Driver logged out from selected vehicle\", function () {\r",
              "    pm.expect(response.driverId).to.eql(Number(pm.environment.get(\"driverId\")));\r",
              "    pm.expect(response.vehicleId).to.eql(Number(pm.environment.get(\"vehicleId\")));\r",
              "});\r",
              "\r",
              "pm.test(\"Logout date was registered\", function () {\r",
              "    pm.expect(response.logoutDate).to.not.be.null;\r",
              "});\r",
              "\r",
              "pm.test(\"Login occurred before logout\", function () {\r",
              "    pm.expect(new Date(response.logoutDate).getTime())\r",
              "        .to.be.greaterThan(new Date(response.loginDate).getTime());\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disabledSystemHeaders": {}
      },
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "{{authorization}}",
            "type": "text"
          },
          {
            "key": "Customer",
            "value": "{{customerId}}",
            "type": "text"
          },
          {
            "key": "Login",
            "value": "{{login}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/driverapp/vehicle/logout?vehicleId={{vehicleId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "driverapp",
            "vehicle",
            "logout"
          ],
          "query": [
            {
              "key": "vehicleId",
              "value": "{{vehicleId}}"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "05 - Logout",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Logout redirect URL is valid\", function () {\r",
              "    pm.expect(response).to.be.a(\"string\");\r",
              "    pm.expect(response).to.eql(\"https://app.trixlog.com\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disabledSystemHeaders": {}
      },
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "{{authorization}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/driverapp/logout",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "driverapp",
